#!/bin/zsh
# Check if dependencies from Brewfile are installed
# Usage: check-deps [brewfile_path]

local brewfile="${1:-$(dirname $0:h)/Brewfile}"

if [[ ! -r "$brewfile" ]]; then
  print "Error: Brewfile not found: $brewfile" >&2
  return 1
fi

local missing_deps=()

while IFS= read -r line; do
  # Skip comments and empty lines
  [[ "$line" =~ ^[[:space:]]*# ]] && continue
  [[ -z "$line" ]] && continue
  
  # Extract package name from brew "package" lines
  if [[ "$line" =~ ^brew[[:space:]]+\"([^\"]+)\" ]]; then
    local pkg="${match[1]}"
    
    # Check if package is installed
    case "$pkg" in
      zsh-fast-syntax-highlighting)
        # Plugin file check
        local fsh_found=0
        local -a fsh_paths=(
          "/opt/homebrew/share/zsh-fast-syntax-highlighting"
          "/usr/local/share/zsh-fast-syntax-highlighting"
          "${HOMEBREW_PREFIX:-}/share/zsh-fast-syntax-highlighting"
        )
        for fsh_path in $fsh_paths; do
          if [[ -r "$fsh_path/fast-syntax-highlighting.plugin.zsh" ]]; then
            fsh_found=1
            break
          fi
        done
        (( ! fsh_found )) && missing_deps+=("$pkg")
        ;;
      neovim)
        # Command is 'nvim'
        if ! command -v nvim &>/dev/null; then
          missing_deps+=("$pkg")
        fi
        ;;
      ripgrep)
        # Command is 'rg'
        if ! command -v rg &>/dev/null; then
          missing_deps+=("$pkg")
        fi
        ;;
      *)
        # Standard case: package name matches command
        if ! command -v "$pkg" &>/dev/null; then
          missing_deps+=("$pkg")
        fi
        ;;
    esac
  fi
done < "$brewfile"

if (( ${#missing_deps} > 0 )); then
  print ""
  print "⚠️  Missing dependencies from Brewfile:"
  for dep in $missing_deps; do
    print "  - $dep"
  done
  print ""
  print "Install them with:"
  print "  brew bundle install --file=$brewfile"
  return 1
else
  print "✅ All dependencies from Brewfile installed"
  return 0
fi
