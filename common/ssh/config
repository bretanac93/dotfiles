# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

# SSH configuration
# This file is managed by dotfiles - edit ssh/config instead
# Keys are exported from 1Password by setup-ssh script
# NOTE: 1Password SSH agent is disabled - using local keys only

# Disable any SSH agent (including 1Password agent)
Host *
  IdentityAgent none
  IdentitiesOnly yes

# GitHub authentication (using Legacy SSH Key from 1Password)
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_rsa
  IdentitiesOnly yes
