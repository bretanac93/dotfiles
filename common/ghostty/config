font-family="JetBrainsMono Nerd Font Mono"
font-size=14
font-thicken = true
font-feature = -calt

# Theme
theme = Nord

# Cursor style
# Zsh vim mode controls this dynamically:
# - Block cursor, blinking in insert mode (via \e[1 q)
# - Block cursor, solid in normal mode (via \e[2 q)
cursor-style = block
cursor-color = #d8dee9
cursor-text = #1e2127
cursor-opacity = 0.8

# Enable cursor blinking
cursor-style-blink = true

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,ssh-env,ssh-terminfo,path

# Key remappings
macos-option-as-alt = true

# Performance
window-vsync = false
auto-update = check

# Window padding for better readability
window-padding-x = 8
window-padding-y = 8

# Scrollback
scrollback-limit = 100000
mouse-scroll-multiplier = 2
