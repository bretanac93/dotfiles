#compdef mdf
#
# Shell completions for mdf (My Dotfiles Manager)

local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
    '1: :->command' \
    '*:: :->args'

case "$state" in
    command)
        local -a commands
        commands=(
            'install:Run init.sh to set up dotfiles'
            'update:Pull latest changes and re-run init'
            'doctor:Check if everything is working'
            'benchmark:Benchmark zsh startup performance'
            'cleanup:Remove old backups'
            'uninstall:Remove dotfiles'
            'aliases:Show available aliases'
            'ssh:Export SSH keys from 1Password'
            'git:Configure git with GPG signing'
            'version:Show version'
            'help:Show help'
        )
        _describe -t commands 'mdf command' commands
        ;;
    args)
        case "$line[1]" in
            benchmark)
                _arguments \
                    '--runs=[Number of measured runs per mode]:runs' \
                    '--warmup=[Number of warmup runs per mode]:warmup' \
                    '--shell=[Shell executable to benchmark]:shell:_command_names' \
                    '--no-local[Disable loading ~/.config/zsh.local during benchmark runs]'
                ;;
            uninstall|cleanup)
                _arguments '--dry-run[Preview what would be removed]'
                ;;
        esac
        ;;
esac
