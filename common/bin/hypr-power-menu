#!/usr/bin/env bash

set -euo pipefail

menu() {
  if command -v walker >/dev/null 2>&1 && command -v elephant >/dev/null 2>&1; then
    walker --dmenu --placeholder "$1"
  elif command -v wofi >/dev/null 2>&1; then
    wofi --dmenu --prompt "$1" --width 220 --lines 5 --hide-scroll
  else
    printf '%s\n' 'walker or wofi is required for hypr-power-menu' >&2
    exit 1
  fi
}

choice="$({
  printf '%s\n' 'lock'
  printf '%s\n' 'logout'
  printf '%s\n' 'suspend'
  printf '%s\n' 'reboot'
  printf '%s\n' 'shutdown'
} | menu 'power')"

case "$choice" in
  lock)
    if command -v hyprlock >/dev/null 2>&1; then
      exec hyprlock
    fi
    exec loginctl lock-session
    ;;
  logout)
    exec hyprctl dispatch exit
    ;;
  suspend)
    if command -v hyprlock >/dev/null 2>&1; then
      hyprlock &
      sleep 1
    fi
    exec systemctl suspend
    ;;
  reboot)
    exec systemctl reboot
    ;;
  shutdown)
    exec systemctl poweroff
    ;;
  *)
    exit 0
    ;;
esac
