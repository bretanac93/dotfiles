#!/usr/bin/env python3

import json
import os
import socket
import subprocess
import time


PIP_TITLES = {"Picture in picture", "Picture-in-Picture"}
MARGIN_X = 20
MARGIN_Y = 20


def hypr_json(*args):
    return json.loads(subprocess.check_output(["hyprctl", *args, "-j"]))


def place_pip(address: str) -> None:
    clients = hypr_json("clients")
    client = next((c for c in clients if c.get("address") == address), None)
    if not client or client.get("title") not in PIP_TITLES:
        return

    monitors = hypr_json("monitors")
    monitor = next((m for m in monitors if m.get("id") == client.get("monitor")), None)
    if not monitor:
        return

    x = monitor["x"] + monitor["width"] - client["size"][0] - MARGIN_X
    y = monitor["y"] + monitor["height"] - client["size"][1] - MARGIN_Y

    subprocess.run(
        [
            "hyprctl",
            "dispatch",
            "movewindowpixel",
            f"exact {x} {y},address:{address}",
        ],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    subprocess.run(
        ["hyprctl", "dispatch", "pin", f"address:{address}"],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def handle_event(line: str) -> None:
    if not line.startswith(("openwindow>>", "windowtitle>>")):
        return

    payload = line.split(">>", 1)[1].split(",")
    if not payload:
        return

    address = payload[0]

    for _ in range(10):
        try:
            place_pip(address)
            break
        except Exception:
            time.sleep(0.15)


def main() -> None:
    sig = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
    runtime = os.environ.get("XDG_RUNTIME_DIR")
    if not sig or not runtime:
        raise SystemExit(0)

    sock_path = os.path.join(runtime, "hypr", sig, ".socket2.sock")
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(sock_path)
        buffer = ""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            buffer += chunk.decode(errors="ignore")
            while "\n" in buffer:
                line, buffer = buffer.split("\n", 1)
                handle_event(line)


if __name__ == "__main__":
    main()
