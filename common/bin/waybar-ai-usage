#!/usr/bin/env python3
import json, subprocess

def get_usage(cmd):
    try:
        out = subprocess.check_output(cmd, text=True, timeout=15)
        return json.loads(out.strip())
    except Exception:
        return None

claude = get_usage(["/usr/bin/claude-usage", "--waybar", "--browser", "vivaldi"])
codex  = get_usage(["/usr/bin/codex-usage",  "--waybar", "--browser", "vivaldi"])

def parse_windows(tooltip):
    five_h = seven_d = None
    for line in tooltip.split("\n"):
        parts = line.split()
        if "5-Hour" in line and len(parts) >= 3:
            five_h = (parts[-2], parts[-1])  # (used%, reset)
        if "7-Day" in line and len(parts) >= 3:
            seven_d = (parts[-2], parts[-1])
    return five_h, seven_d

lines = []
claude_pct = 0
codex_pct  = 0

if claude:
    claude_pct = claude.get("percentage", 0)
    five_h, seven_d = parse_windows(claude.get("tooltip", ""))
    lines.append("Claude")
    if five_h:
        lines.append(f"  5h    {five_h[0]:>4}   resets in {five_h[1]}")
    if seven_d:
        lines.append(f"  7d    {seven_d[0]:>4}   resets in {seven_d[1]}")
else:
    lines.append("Claude  unavailable")

lines.append("")

if codex:
    codex_pct = codex.get("percentage", 0)
    five_h, seven_d = parse_windows(codex.get("tooltip", ""))
    lines.append("Codex")
    if five_h:
        lines.append(f"  5h    {five_h[0]:>4}   resets in {five_h[1]}")
    if seven_d:
        lines.append(f"  7d    {seven_d[0]:>4}   resets in {seven_d[1]}")
else:
    lines.append("Codex   unavailable")

max_pct = max(claude_pct, codex_pct)
css_class = "ai-high" if max_pct >= 80 else ("ai-mid" if max_pct >= 50 else "ai-low")

print(json.dumps({
    "text": "󱚦",
    "tooltip": "\n".join(lines),
    "class": css_class,
}))
