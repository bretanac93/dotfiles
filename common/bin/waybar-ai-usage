#!/usr/bin/env python3
import json, subprocess

def get_usage(cmd):
    try:
        out = subprocess.check_output(cmd, text=True, timeout=15)
        return json.loads(out.strip())
    except Exception:
        return None

claude = get_usage(["/usr/bin/claude-usage", "--waybar", "--browser", "chrome"])
codex  = get_usage(["/usr/bin/codex-usage",  "--waybar", "--browser", "chrome"])

def parse_windows(tooltip):
    five_h = seven_d = None
    for line in tooltip.split("\n"):
        parts = line.split()
        if "5-Hour" in line and len(parts) >= 3:
            five_h = (parts[-2], parts[-1])  # (used%, reset)
        if "7-Day" in line and len(parts) >= 3:
            seven_d = (parts[-2], parts[-1])
    return five_h, seven_d

def append_usage(name, usage):
    if not usage:
        lines.append(f"{name:<7} unavailable")
        return 0, False

    usage_class = usage.get("class", "")
    tooltip = usage.get("tooltip", "")
    if "critical" in usage_class:
        lines.append(f"{name}")
        for line in tooltip.split("\n"):
            line = line.strip()
            if line and line != "Error:":
                lines.append(f"  {line}")
        return 0, True

    pct = usage.get("percentage", 0)
    five_h, seven_d = parse_windows(tooltip)
    lines.append(name)
    if five_h:
        lines.append(f"  5h    {five_h[0]:>4}   resets in {five_h[1]}")
    if seven_d:
        lines.append(f"  7d    {seven_d[0]:>4}   resets in {seven_d[1]}")
    return pct, False

lines = []
claude_pct, claude_critical = append_usage("Claude", claude)

lines.append("")

codex_pct, codex_critical = append_usage("Codex", codex)

max_pct = max(claude_pct, codex_pct)
css_class = "critical" if claude_critical or codex_critical else ("ai-high" if max_pct >= 80 else ("ai-mid" if max_pct >= 50 else "ai-low"))

print(json.dumps({
    "text": "",
    "tooltip": "\n".join(lines),
    "class": css_class,
}))
