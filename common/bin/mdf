#!/usr/bin/env zsh
#
# mdf - My Dotfiles Manager
# Usage: mdf <command> [options]

set -e

# Find the actual script location (resolve symlinks)
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"
COMMON_DIR="${SCRIPT_DIR:h}"
DOTFILES_DIR="${COMMON_DIR:h}"

VERSION="1.0.0"

show_help() {
    cat << EOF
mdf - My Dotfiles Manager v${VERSION}

Usage: mdf <command> [options]

Commands:
  install, i       Run init.sh to set up dotfiles
  update, u        Pull latest changes and re-run init
  deps             Install platform dependencies
  arch             Run Arch-specific setup helpers
  doctor, d        Check if everything is working
  benchmark, b     Benchmark zsh startup performance
  uninstall       Remove dotfiles (with --dry-run support)
  aliases, a      Show available aliases
  shortcuts, s    Show Hyprland keyboard shortcuts
  
Setup Commands:
  ssh              Export SSH keys from 1Password
  git              Configure git with GPG signing from 1Password
  
Other:
  version, v       Show version
  help, h          Show this help

Examples:
  mdf install              # First time setup
  mdf install --force-symlinks
  mdf update               # Update to latest
  mdf doctor               # Check health
  mdf arch --setup-sddm    # Install tracked SDDM theme
  mdf arch --test-sddm     # Preview the installed SDDM theme
  mdf benchmark            # Measure shell startup time
  mdf aliases              # Show all aliases
  mdf shortcuts            # Show Hyprland keybind cheat sheet
  mdf uninstall --dry-run  # Preview uninstall

EOF
}

show_shortcuts() {
    cat << 'EOF'
Hyprland Shortcuts

Launchers:
  Super + Space        App launcher
  Alt + Space          App launcher
  Super + Return       Terminal
  Super + E            File manager

Window Actions:
  Super + Q            Close focused window
  Super + F            Fullscreen
  Super + Shift + F    Toggle floating
  Super + P            Toggle pseudotile
  Super + \            Toggle split direction
  Super + Tab          Next window
  Super + Shift + Tab  Previous window
  Super + `            Toggle scratch workspace
  Super + Shift + `    Send window to scratch workspace
  Super + M            Exit / power menu
  Ctrl + Alt + L       Lock screen
  Super + Shift + 3    Save full screenshot
  Super + Shift + 4    Save selection screenshot
  Super + Shift + 5    Screenshot menu
  Super + Ctrl + Shift + 3  Copy full screenshot
  Super + Ctrl + Shift + 4  Copy selection screenshot

Focus:
  Super + H/J/K/L      Focus left/down/up/right
  Super + Arrow keys   Focus left/down/up/right

Move Windows:
  Super + Shift + H/J/K/L   Move window left/down/up/right

Resize Windows:
  Super + Ctrl + H/J/K/L    Resize left/down/up/right

Workspaces:
  Super + 1..0         Switch to workspace 1..10
  Super + Shift + 1..0 Move window to workspace 1..10
  Super + mouse wheel  Cycle workspaces

Mouse:
  Super + Left drag    Move window
  Super + Right drag   Resize window

Media / Hardware:
  XF86AudioRaiseVolume / XF86AudioLowerVolume
  XF86AudioMute / XF86AudioMicMute
  XF86AudioPlay / XF86AudioPause / XF86AudioNext / XF86AudioPrev
  XF86MonBrightnessUp / XF86MonBrightnessDown

Tip:
  `hyprctl binds` shows the live bind list from Hyprland, but it is more raw than this cheat sheet.
EOF
}

show_aliases() {
    COMMON_DIR="$COMMON_DIR" ZSH_LOCAL_CONFIG_DIR="${ZSH_LOCAL_CONFIG_DIR:-$HOME/.config/zsh.local}" zsh -f <<'EOF'
setopt localoptions extendedglob no_aliases

group_title_for_file() {
    local alias_file="$1"
    local alias_name="${alias_file:t:r}"

    case "$alias_name" in
        git)
            print "Git Aliases"
            ;;
        navigation)
            print "Navigation Aliases"
            ;;
        editor)
            print "Editor Aliases"
            ;;
        k8s)
            print "Kubernetes Aliases"
            ;;
        *)
            print "${alias_name} Aliases"
            ;;
    esac
}

print_alias_group() {
    local title="$1"
    shift

    (( $# == 0 )) && return

    print "$title:"
    local alias_name
    for alias_name in "$@"; do
        printf '  %-10s -> %s\n' "$alias_name" "${aliases[$alias_name]}"
    done
    print ""
}

source_alias_file() {
    local title="$1"
    local alias_file="$2"
    local -A before_aliases after_aliases
    local -a changed_aliases
    local alias_name

    [[ -r "$alias_file" ]] || return 0

    before_aliases=("${(@kv)aliases}")
    source "$alias_file"
    after_aliases=("${(@kv)aliases}")

    for alias_name in ${(ok)after_aliases}; do
        if [[ "${before_aliases[$alias_name]-__missing__}" != "${after_aliases[$alias_name]}" ]]; then
            changed_aliases+=("$alias_name")
        fi
    done

    print_alias_group "$title" ${(on)changed_aliases}
}

print "Dotfiles Aliases"
print ""

local alias_file
for alias_file in "$COMMON_DIR"/zsh/alias/*.zsh(N); do
    source_alias_file "$(group_title_for_file "$alias_file")" "$alias_file"
done

for alias_file in "$ZSH_LOCAL_CONFIG_DIR"/alias/*.zsh(N); do
    source_alias_file "Local Aliases (${alias_file:t:r})" "$alias_file"
done

print "Run 'alias | grep TERM' to find specific aliases in your shell"
EOF
}

run_script() {
    local script="$1"
    shift
    
    if [[ -x "$COMMON_DIR/bin/$script" ]]; then
        exec "$COMMON_DIR/bin/$script" "$@"
    elif [[ -x "$DOTFILES_DIR/scripts/$script" ]]; then
        exec "$DOTFILES_DIR/scripts/$script" "$@"
    elif [[ -x "$DOTFILES_DIR/macos/scripts/$script" ]]; then
        exec "$DOTFILES_DIR/macos/scripts/$script" "$@"
    else
        echo "❌ Command not found: $script"
        exit 1
    fi
}

# Parse command
case "${1:-}" in
    install|i)
        shift
        cd "$DOTFILES_DIR"
        exec ./init.sh "$@"
        ;;
        
    update|u)
        shift
        run_script "dotfiles-update" "$@"
        ;;

    deps)
        shift
        run_script "install-deps" "$@"
        ;;

    arch)
        shift
        case "${1:-}" in
            --setup-sddm)
                shift
                run_script "setup-sddm-theme" "$@"
                ;;
            --test-sddm)
                shift
                run_script "test-sddm-theme" "$@"
                ;;
            *)
                echo "❌ Unknown arch option: ${1:-<none>}"
                echo ""
                echo "Available options:"
                echo "  --setup-sddm    Install the tracked SDDM Astronaut theme"
                echo "  --test-sddm     Preview the installed SDDM Astronaut theme"
                exit 1
                ;;
        esac
        ;;
          
    doctor|d)
        shift
        run_script "dotfiles-doctor" "$@"
        ;;

    benchmark|b)
        shift
        run_script "dotfiles-benchmark" "$@"
        ;;
         
    cleanup|c)
        shift
        run_script "dotfiles-cleanup-backups" "$@"
        ;;
        
    uninstall|remove|rm)
        shift
        run_script "dotfiles-uninstall" "$@"
        ;;
        
    ssh)
        shift
        run_script "setup-ssh" "$@"
        ;;
        
    git)
        shift
        run_script "setup-git-local" "$@"
        ;;
        
    aliases|a)
        show_aliases
        exit 0
        ;;

    shortcuts|shortcut|keys|keybinds|s)
        show_shortcuts
        exit 0
        ;;
         
    version|v|--version|-v)
        echo "mdf version ${VERSION}"
        exit 0
        ;;
        
    help|h|--help|-h|"")
        show_help
        exit 0
        ;;
        
    *)
        echo "❌ Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
