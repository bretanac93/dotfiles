#!/usr/bin/env zsh
#
# mdf - My Dotfiles Manager
# Usage: mdf <command> [options]

set -e

# Find the actual script location (resolve symlinks)
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"
COMMON_DIR="${SCRIPT_DIR:h}"
DOTFILES_DIR="${COMMON_DIR:h}"

VERSION="1.0.0"

show_help() {
    cat << EOF
mdf - My Dotfiles Manager v${VERSION}

Usage: mdf <command> [options]

Commands:
  install, i       Run init.sh to set up dotfiles
  update, u        Pull latest changes and re-run init
  deps             Install platform dependencies
  doctor, d        Check if everything is working
  benchmark, b     Benchmark zsh startup performance
  uninstall       Remove dotfiles (with --dry-run support)
  aliases, a      Show available aliases
  
Setup Commands:
  ssh              Export SSH keys from 1Password
  git              Configure git with GPG signing from 1Password
  
Other:
  version, v       Show version
  help, h          Show this help

Examples:
  mdf install              # First time setup
  mdf install --force-symlinks
  mdf update               # Update to latest
  mdf doctor               # Check health
  mdf benchmark            # Measure shell startup time
  mdf aliases              # Show all aliases
  mdf uninstall --dry-run  # Preview uninstall

EOF
}

show_aliases() {
    COMMON_DIR="$COMMON_DIR" ZSH_LOCAL_CONFIG_DIR="${ZSH_LOCAL_CONFIG_DIR:-$HOME/.config/zsh.local}" zsh -f <<'EOF'
setopt localoptions extendedglob no_aliases

group_title_for_file() {
    local alias_file="$1"
    local alias_name="${alias_file:t:r}"

    case "$alias_name" in
        git)
            print "Git Aliases"
            ;;
        navigation)
            print "Navigation Aliases"
            ;;
        editor)
            print "Editor Aliases"
            ;;
        k8s)
            print "Kubernetes Aliases"
            ;;
        *)
            print "${alias_name} Aliases"
            ;;
    esac
}

print_alias_group() {
    local title="$1"
    shift

    (( $# == 0 )) && return

    print "$title:"
    local alias_name
    for alias_name in "$@"; do
        printf '  %-10s -> %s\n' "$alias_name" "${aliases[$alias_name]}"
    done
    print ""
}

source_alias_file() {
    local title="$1"
    local alias_file="$2"
    local -A before_aliases after_aliases
    local -a changed_aliases
    local alias_name

    [[ -r "$alias_file" ]] || return 0

    before_aliases=("${(@kv)aliases}")
    source "$alias_file"
    after_aliases=("${(@kv)aliases}")

    for alias_name in ${(ok)after_aliases}; do
        if [[ "${before_aliases[$alias_name]-__missing__}" != "${after_aliases[$alias_name]}" ]]; then
            changed_aliases+=("$alias_name")
        fi
    done

    print_alias_group "$title" ${(on)changed_aliases}
}

print "Dotfiles Aliases"
print ""

local alias_file
for alias_file in "$COMMON_DIR"/zsh/alias/*.zsh(N); do
    source_alias_file "$(group_title_for_file "$alias_file")" "$alias_file"
done

for alias_file in "$ZSH_LOCAL_CONFIG_DIR"/alias/*.zsh(N); do
    source_alias_file "Local Aliases (${alias_file:t:r})" "$alias_file"
done

print "Run 'alias | grep TERM' to find specific aliases in your shell"
EOF
}

run_script() {
    local script="$1"
    shift
    
    if [[ -x "$COMMON_DIR/bin/$script" ]]; then
        exec "$COMMON_DIR/bin/$script" "$@"
    elif [[ -x "$DOTFILES_DIR/scripts/$script" ]]; then
        exec "$DOTFILES_DIR/scripts/$script" "$@"
    elif [[ -x "$DOTFILES_DIR/macos/scripts/$script" ]]; then
        exec "$DOTFILES_DIR/macos/scripts/$script" "$@"
    else
        echo "❌ Command not found: $script"
        exit 1
    fi
}

# Parse command
case "${1:-}" in
    install|i)
        shift
        cd "$DOTFILES_DIR"
        exec ./init.sh "$@"
        ;;
        
    update|u)
        shift
        run_script "dotfiles-update" "$@"
        ;;

    deps)
        shift
        run_script "install-deps" "$@"
        ;;
         
    doctor|d)
        shift
        run_script "dotfiles-doctor" "$@"
        ;;

    benchmark|b)
        shift
        run_script "dotfiles-benchmark" "$@"
        ;;
         
    cleanup|c)
        shift
        run_script "dotfiles-cleanup-backups" "$@"
        ;;
        
    uninstall|remove|rm)
        shift
        run_script "dotfiles-uninstall" "$@"
        ;;
        
    ssh)
        shift
        run_script "setup-ssh" "$@"
        ;;
        
    git)
        shift
        run_script "setup-git-local" "$@"
        ;;
        
    aliases|a)
        show_aliases
        exit 0
        ;;
        
    version|v|--version|-v)
        echo "mdf version ${VERSION}"
        exit 0
        ;;
        
    help|h|--help|-h|"")
        show_help
        exit 0
        ;;
        
    *)
        echo "❌ Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
