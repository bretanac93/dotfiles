#!/usr/bin/env python3
# USAGE: waybar-vpn
# Outputs JSON for waybar. Shows icon when any VPN tunnel is active.
# VPN_ICON codepoint (U+E2C0) is a Phosphor lock variant — update if wrong.
import json, subprocess

VPN_ICON = chr(0xe2c0)
VPN_TYPES = {"wireguard": "WireGuard", "tun": "OpenVPN"}

def active_vpn():
    try:
        result = subprocess.run(["ip", "-j", "link"], capture_output=True, text=True)
        for link in json.loads(result.stdout):
            if (link.get("link_type") in VPN_TYPES and
                    link.get("operstate") in ("UP", "UNKNOWN")):
                return link["ifname"], VPN_TYPES[link["link_type"]]
    except Exception:
        pass
    return None


vpn = active_vpn()
if vpn:
    iface, kind = vpn
    print(json.dumps({
        "text": f"<span font_family='Phosphor'>{VPN_ICON}</span>",
        "tooltip": f"{kind}  {iface}",
        "class": "vpn-active",
    }))
else:
    print(json.dumps({"text": "", "tooltip": "No VPN", "class": "vpn-off"}))
