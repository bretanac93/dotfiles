#!/bin/zsh

set -euo pipefail

script_name="${0:t}"

usage() {
  local fd="${1:-2}"

  print -u"$fd" "Usage: ${script_name} [directory] [-c|--claude|-x|--codex|-o|--opencode] [-w|--with-worktree <branch>]"
  print -u"$fd" ""
  print -u"$fd" "Build a tmux coding layout for a folder:"
  print -u"$fd" "  top-left     editor command (default: nvim)"
  print -u"$fd" "  bottom-left  shell"
  print -u"$fd" "  right        selected assistant CLI"
  print -u"$fd" ""
  print -u"$fd" "Inside tmux, this reuses the current window when it has a single pane."
  print -u"$fd" "If the current window is already split, it opens a new window instead."
  print -u"$fd" ""
  print -u"$fd" "Options:"
  print -u"$fd" "  -c, --claude    open Claude on the right"
  print -u"$fd" "  -x, --codex     open Codex on the right"
  print -u"$fd" "  -o, --opencode  open OpenCode on the right"
  print -u"$fd" "  -w, --with-worktree <branch>"
  print -u"$fd" "                  create or reuse a git worktree for <branch>"
  print -u"$fd" "                  opens the matching directory inside that worktree"
  print -u"$fd" "  -h, --help      show this help"
  print -u"$fd" ""
  print -u"$fd" "Environment:"
  print -u"$fd" "  WB_EDITOR       override the left editor command"
  print -u"$fd" "                  falls back to \$EDITOR, then nvim"
  print -u"$fd" "  WB_DEFAULT_ASSISTANT"
  print -u"$fd" "                  set the default right pane assistant"
  print -u"$fd" "                  supports: opencode, claude, codex"
  print -u"$fd" "                  falls back to opencode"
  print -u"$fd" "  WB_OPENCODE_PORT"
  print -u"$fd" "                  override the port used when the assistant is opencode"
  print -u"$fd" "                  when unset, wb picks an available port automatically"
  print -u"$fd" "  WB_WORKTREE_ROOT"
  print -u"$fd" "                  root directory for centralized git worktrees"
  print -u"$fd" "                  defaults to $HOME/.worktrees"
  print -u"$fd" ""
  print -u"$fd" "Examples:"
  print -u"$fd" "  ${script_name}"
  print -u"$fd" "  ${script_name} ~/Code/my-project"
  print -u"$fd" "  ${script_name} -c ~/Code/my-project"
  print -u"$fd" "  ${script_name} --with-worktree feature/my-branch ~/Code/my-project"
  print -u"$fd" "  WB_DEFAULT_ASSISTANT=claude ${script_name}"
  print -u"$fd" "  WB_EDITOR=vim ${script_name} -x"
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    print -u2 "Missing required command: $1"
    exit 1
  fi
}

sanitize_name() {
  local value="$1"

  value="${value//[^A-Za-z0-9_.-]/-}"
  value="${value##-}"
  value="${value%%-}"

  if [[ -z "$value" ]]; then
    value="workspace"
  fi

  print -r -- "$value"
}

unique_session_name() {
  local base="$1"
  local candidate="$base"
  local suffix=2

  while tmux has-session -t "$candidate" >/dev/null 2>&1; do
    candidate="${base}-${suffix}"
    ((suffix++))
  done

  print -r -- "$candidate"
}

unique_window_name() {
  local session_name="$1"
  local base="$2"
  local candidate="$base"
  local suffix=2

  while tmux list-windows -t "$session_name" -F '#{window_name}' 2>/dev/null | grep -Fxq -- "$candidate"; do
    candidate="${base}-${suffix}"
    ((suffix++))
  done

  print -r -- "$candidate"
}

resolve_assistant_command() {
  case "$1" in
    opencode|open-code|o)
      print -r -- "opencode"
      ;;
    claude|claude-code|c|cc)
      print -r -- "claude"
      ;;
    codex|x|cx)
      print -r -- "codex"
      ;;
    *)
      print -u2 "Unsupported assistant: $1"
      print -u2 "Use one of: opencode, claude, codex"
      exit 1
      ;;
  esac
}

pick_opencode_port() {
  if [[ -n "${WB_OPENCODE_PORT:-}" ]]; then
    if [[ "$WB_OPENCODE_PORT" != <-> ]]; then
      print -u2 "WB_OPENCODE_PORT must be a number"
      exit 1
    fi

    print -r -- "$WB_OPENCODE_PORT"
    return
  fi

  if ! command -v python3 >/dev/null 2>&1; then
    print -u2 "Missing required command: python3"
    exit 1
  fi

  python3 -c 'import socket; s = socket.socket(); s.bind(("127.0.0.1", 0)); print(s.getsockname()[1]); s.close()'
}

branch_worktree_path() {
  local repo_root="$1"
  local branch_name="$2"
  local line
  local current_worktree=""
  local current_branch=""

  while IFS= read -r line; do
    if [[ -z "$line" ]]; then
      if [[ "$current_branch" == "refs/heads/$branch_name" && -n "$current_worktree" ]]; then
        print -r -- "$current_worktree"
        return 0
      fi

      current_worktree=""
      current_branch=""
      continue
    fi

    if [[ "$line" == worktree\ * ]]; then
      current_worktree="${line#worktree }"
    elif [[ "$line" == branch\ * ]]; then
      current_branch="${line#branch }"
    fi
  done < <(git -C "$repo_root" worktree list --porcelain)

  if [[ "$current_branch" == "refs/heads/$branch_name" && -n "$current_worktree" ]]; then
    print -r -- "$current_worktree"
  fi
}

default_worktree_root() {
  print -r -- "${WB_WORKTREE_ROOT:-$HOME/.worktrees}"
}

worktree_repo_dir() {
  local repo_root="$1"
  local storage_root="$2"
  local relative_repo_path=""

  if [[ "$repo_root" == "$HOME" ]]; then
    relative_repo_path="home"
  elif [[ "$repo_root" == "$HOME"/* ]]; then
    relative_repo_path="${repo_root#$HOME/}"
  else
    relative_repo_path="external/${repo_root#/}"
  fi

  print -r -- "$storage_root/$relative_repo_path"
}

resolve_worktree_target() {
  local start_dir="$1"
  local branch_name="$2"
  local repo_root=""
  local relative_subdir=""
  local existing_worktree=""
  local worktree_root=""
  local storage_root=""
  local repo_worktree_dir=""

  if ! repo_root="$(git -C "$start_dir" rev-parse --show-toplevel 2>/dev/null)"; then
    print -u2 "--with-worktree requires a directory inside a git repository"
    exit 1
  fi

  repo_root="$(cd "$repo_root" && pwd -P)"

  if ! git -C "$repo_root" check-ref-format --branch "$branch_name" >/dev/null 2>&1; then
    print -u2 "Invalid branch name: $branch_name"
    exit 1
  fi

  if [[ "$start_dir" != "$repo_root" ]]; then
    relative_subdir="${start_dir#$repo_root/}"
  fi

  existing_worktree="$(branch_worktree_path "$repo_root" "$branch_name")"
  if [[ -n "$existing_worktree" ]]; then
    worktree_root="$existing_worktree"
  else
    storage_root="$(default_worktree_root)"
    repo_worktree_dir="$(worktree_repo_dir "$repo_root" "$storage_root")"
    worktree_root="$repo_worktree_dir/$branch_name"

    if [[ -e "$worktree_root" ]]; then
      print -u2 "Worktree path already exists: $worktree_root"
      exit 1
    fi

    mkdir -p "$worktree_root:h"

    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch_name"; then
      git -C "$repo_root" worktree add "$worktree_root" "$branch_name" >/dev/null
    else
      git -C "$repo_root" worktree add -b "$branch_name" "$worktree_root" >/dev/null
    fi
  fi

  if [[ -n "$relative_subdir" && -d "$worktree_root/$relative_subdir" ]]; then
    print -r -- "$worktree_root/$relative_subdir"
    return 0
  fi

  print -r -- "$worktree_root"
}

assistant_command="$(resolve_assistant_command "${WB_DEFAULT_ASSISTANT:-opencode}")"
editor_command="${WB_EDITOR:-${EDITOR:-nvim}}"
editor_words=(${(z)editor_command})
editor_executable="${editor_words[1]:-}"
target_dir=""
worktree_branch=""

if [[ -z "$editor_executable" ]]; then
  print -u2 "Editor command cannot be empty"
  exit 1
fi

while (( $# > 0 )); do
  case "$1" in
    -c|--claude)
      assistant_command="claude"
      ;;
    -x|--codex)
      assistant_command="codex"
      ;;
    -o|--opencode)
      assistant_command="opencode"
      ;;
    -w|--with-worktree)
      shift

      if (( $# == 0 )) || [[ "$1" == -* ]]; then
        print -u2 "Missing branch name for --with-worktree"
        usage
        exit 1
      fi

      worktree_branch="$1"
      ;;
    --with-worktree=*)
      worktree_branch="${1#*=}"

      if [[ -z "$worktree_branch" ]]; then
        print -u2 "Missing branch name for --with-worktree"
        usage
        exit 1
      fi
      ;;
    -h|--help)
      usage 1
      exit 0
      ;;
    -*)
      print -u2 "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      if [[ -n "$target_dir" ]]; then
        usage
        exit 1
      fi

      target_dir="$1"
      ;;
  esac

  shift
done

require_command tmux
require_command "$editor_executable"
require_command "$assistant_command"

target_dir="${target_dir:-$PWD}"

if [[ ! -d "$target_dir" ]]; then
  print -u2 "Directory not found: $target_dir"
  exit 1
fi

target_dir="$(cd "$target_dir" && pwd -P)"
worktree_root=""

if [[ -n "$worktree_branch" ]]; then
  require_command git
  target_dir="$(resolve_worktree_target "$target_dir" "$worktree_branch")"
  worktree_root="$(git -C "$target_dir" rev-parse --show-toplevel)"
fi

workspace_name_source="${target_dir:t}"
if [[ -n "$worktree_root" ]]; then
  workspace_name_source="${worktree_root:t}"
fi

workspace_name="$(sanitize_name "$workspace_name_source")"
right_pane_width=38
bottom_pane_height=22
reuse_current_window=0
opencode_port=""

if [[ "$assistant_command" == "opencode" ]]; then
  opencode_port="$(pick_opencode_port)"
fi

if [[ -n "${TMUX:-}" ]]; then
  session_name="$(tmux display-message -p '#S')"
  if [[ "$(tmux display-message -p '#{window_panes}')" == "1" ]]; then
    reuse_current_window=1
    window_id="$(tmux display-message -p '#{window_id}')"
    top_left_pane="$(tmux display-message -p '#{pane_id}')"
  else
    window_name="$(unique_window_name "$session_name" "$workspace_name")"
    top_left_pane="$(tmux new-window -d -P -F '#{pane_id}' -t "$session_name:" -n "$window_name" -c "$target_dir")"
  fi
else
  session_name="$(unique_session_name "$workspace_name")"
  window_name="workspace"
  top_left_pane="$(tmux new-session -d -P -F '#{pane_id}' -s "$session_name" -n "$window_name" -c "$target_dir")"
fi

window_id="${window_id:-$(tmux display-message -p -t "$top_left_pane" '#{window_id}')}"
right_pane="$(tmux split-window -h -P -F '#{pane_id}' -t "$top_left_pane" -c "$target_dir" -p "$right_pane_width")"
bottom_left_pane="$(tmux split-window -v -P -F '#{pane_id}' -t "$top_left_pane" -c "$target_dir" -p "$bottom_pane_height")"

if (( reuse_current_window )) && [[ "$(tmux display-message -p -t "$top_left_pane" '#{pane_current_path}')" != "$target_dir" ]]; then
  tmux send-keys -t "$top_left_pane" "cd -- ${(q)target_dir}" C-m
fi

if [[ -n "$opencode_port" ]]; then
  tmux send-keys -t "$top_left_pane" "export OPENCODE_PORT=${(q)opencode_port}" C-m
  tmux send-keys -t "$bottom_left_pane" "export OPENCODE_PORT=${(q)opencode_port}" C-m
  tmux send-keys -t "$right_pane" "export OPENCODE_PORT=${(q)opencode_port}" C-m
fi

tmux send-keys -t "$top_left_pane" "$editor_command" C-m

if [[ -n "$opencode_port" ]]; then
  tmux send-keys -t "$right_pane" "opencode --port ${(q)opencode_port}" C-m
else
  tmux send-keys -t "$right_pane" "$assistant_command" C-m
fi

tmux select-pane -t "$top_left_pane"

if [[ -n "${TMUX:-}" ]]; then
  tmux select-window -t "$window_id"
else
  exec tmux attach-session -t "$session_name"
fi
