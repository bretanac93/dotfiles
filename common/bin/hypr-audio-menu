#!/usr/bin/env bash

set -euo pipefail

menu() {
  if command -v walker >/dev/null 2>&1 && command -v elephant >/dev/null 2>&1; then
    walker --dmenu --placeholder "$1"
  elif command -v wofi >/dev/null 2>&1; then
    wofi --dmenu --prompt "$1" --width 720 --lines 12 --hide-scroll
  else
    printf '%s\n' 'walker or wofi is required for hypr-audio-menu' >&2
    exit 1
  fi
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '%s\n' "missing dependency: $1" >&2
    exit 1
  }
}

require wpctl

show_profiles() {
  local items
  items="$(python3 - <<'EOF'
import subprocess, re

out = subprocess.check_output(['pactl', 'list', 'cards'], text=True)
blocks = re.split(r'^Card #', out, flags=re.M)[1:]

for block in blocks:
    name_m  = re.search(r'Name:\s+(\S+)', block)
    desc_m  = re.search(r'device\.description\s*=\s*"([^"]+)"', block)
    active_m = re.search(r'Active Profile:\s+(.+)', block)
    if not (name_m and desc_m and active_m):
        continue

    card_name = name_m.group(1)
    card_desc = desc_m.group(1)
    active    = active_m.group(1).strip()

    for m in re.finditer(
        r'^\t\t(\S[^:]+):\s+(.+?)\s+\(sinks:.*?available:\s+(yes|no)',
        block, re.M
    ):
        pid, pdesc, avail = m.group(1).strip(), m.group(2).strip(), m.group(3)
        if pid in ('off', 'pro-audio') and pid != active:
            continue
        if avail == 'no' and pid != active:
            continue
        mark = '✓' if pid == active else ' '
        print(f'{mark}  {card_desc}  {pdesc}  [{card_name}|{pid}]')
EOF
  )"

  [[ -z "$items" ]] && return

  local pick
  pick="$(printf '%s\n' "$items" | menu 'audio profile')" || return 0
  [[ -z "$pick" ]] && return 0

  local card_profile="${pick##*[}"; card_profile="${card_profile%]}"
  local card="${card_profile%%|*}"
  local profile="${card_profile##*|}"
  local desc="${pick#*  }"; desc="${desc%%  *}"

  pactl set-card-profile "$card" "$profile"
  notify-send -a "Audio" -i "audio-card" "Profile switched" "$desc"
}

selection="$({
  printf '🎛  audio profiles\n'
  wpctl status | awk '
    /Sinks:/ {section="sink"; next}
    /Sources:/ {section="source"; next}
    /Sink endpoints:/ {section=""}
    /Source endpoints:/ {section=""}
    section != "" {
      if (match($0, /([*[:space:]]*)[[:graph:]]+[[:space:]]+([0-9]+)\. (.*)/, m)) {
        prefix = section == "sink" ? "out" : "in"
        marker = index(m[1], "*") ? "default" : "      "
        gsub(/[[:space:]]+\[[^]]+\]$/, "", m[3])
        print prefix "  " marker "  " m[3] "  [" m[2] "]"
      }
    }
  '
} | menu 'audio')"

[[ -z "$selection" ]] && exit 0

if [[ "$selection" == '🎛  audio profiles' ]]; then
  show_profiles
  exit 0
fi

id="${selection##*[}"; id="${id%]}"
wpctl set-default "$id"
