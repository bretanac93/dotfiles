#!/usr/bin/env python3
import json, urllib.request

import os
LOCATION = os.environ.get("WAYBAR_WEATHER_LOCATION", "Berlin,Germany")

# wttr.in weather codes → Phosphor icon codepoint
# https://www.worldweatheronline.com/developer/api/docs/weather-icons.aspx
def weather_icon(code, is_night=False):
    code = int(code)
    if code == 113:
        return chr(0xe330) if is_night else chr(0xe472)   # moon / sun
    if code == 116:
        return chr(0xe53e) if is_night else chr(0xe540)   # cloud-moon / cloud-sun
    if code in (119, 122):
        return chr(0xe1aa)                                 # cloud
    if code in (143, 248, 260):
        return chr(0xe53c)                                 # cloud-fog
    if code in (176, 263, 266, 281, 284, 293, 296, 299, 302, 305, 308, 353, 356, 359):
        return chr(0xe1b4)                                 # cloud-rain
    if code in (179, 182, 185, 227, 230, 323, 326, 329, 332, 335, 338, 350, 362, 365, 368, 371, 374, 377):
        return chr(0xe1b8)                                 # cloud-snow
    if code in (200, 386, 389, 392, 395):
        return chr(0xe1b2)                                 # cloud-lightning
    return chr(0xe1aa)                                     # cloud fallback

try:
    url = f"https://wttr.in/{urllib.request.quote(LOCATION)}?format=j1"
    req = urllib.request.Request(url, headers={"User-Agent": "curl/7.0"})
    with urllib.request.urlopen(req, timeout=10) as r:
        data = json.loads(r.read())

    current = data["current_condition"][0]
    code      = current["weatherCode"]
    temp_c    = current["temp_C"]
    feels_c   = current["FeelsLikeC"]
    humidity  = current["humidity"]
    wind_kmph = current["windspeedKmph"]
    desc      = current["weatherDesc"][0]["value"]

    # crude night detection via astronomy
    try:
        astronomy = data["weather"][0]["astronomy"][0]
        from datetime import datetime, time as dtime
        now = datetime.now().time()
        sunrise = datetime.strptime(astronomy["sunrise"], "%I:%M %p").time()
        sunset  = datetime.strptime(astronomy["sunset"],  "%I:%M %p").time()
        is_night = not (sunrise <= now <= sunset)
    except Exception:
        is_night = False

    icon = weather_icon(code, is_night)
    text = f"<span font_family='Phosphor'>{icon}</span> {temp_c}°C"
    tooltip = f"{desc}\nFeels like {feels_c}°C\nHumidity {humidity}%\nWind {wind_kmph} km/h"

    print(json.dumps({"text": text, "tooltip": tooltip, "class": "weather"}))

except Exception as e:
    print(json.dumps({"text": chr(0xe1aa), "tooltip": str(e), "class": "weather-error"}))
