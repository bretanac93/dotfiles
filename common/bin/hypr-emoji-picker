#!/usr/bin/env bash

set -euo pipefail

if command -v walker >/dev/null 2>&1 && command -v elephant >/dev/null 2>&1; then
  exec walker --provider symbols
fi

if command -v rofimoji >/dev/null 2>&1; then
  if command -v wofi >/dev/null 2>&1; then
    exec rofimoji --action copy --selector wofi
  fi
  exec rofimoji --action copy
fi

printf '%s\n' 'hypr-emoji-picker requires walker+elephant or rofimoji' >&2
exit 1
