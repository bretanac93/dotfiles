# Example local environment variables
# Copy this to ~/.config/zsh.local/env.zsh and customize

# Work-specific environment
# export WORK_API_KEY="your-api-key-here"
# export WORK_DB_URL="postgres://localhost/workdb"

# Development settings
# export NODE_ENV="development"
# export RAILS_ENV="development"
# export FLASK_ENV="development"

# API keys for development (don't commit these!)
# export OPENAI_API_KEY="sk-..."
# export ANTHROPIC_API_KEY="sk-ant-..."

# Custom PATH additions
# export PATH="$HOME/work-tools/bin:$PATH"
# export PATH="$HOME/.local/share/gem/bin:$PATH"

# Default editor override (if you want something different from nvim)
# export EDITOR="vim"
# export VISUAL="code --wait"

# Language-specific settings
# export JAVA_HOME="/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home"
# export GOPATH="$HOME/go"
# export GOBIN="$GOPATH/bin"
# export PATH="$GOBIN:$PATH"
