font-family="JetBrainsMono Nerd Font Mono"
font-size=14
font-thicken = true
font-feature = -calt

# Try One Dark theme for better contrast than Nord
theme = one_dark
background = #1e2127
foreground = #abb2bf

# Cursor style
# Zsh vim mode controls this dynamically:
# - Block cursor, blinking in insert mode (via \e[1 q)
# - Block cursor, solid in normal mode (via \e[2 q)
cursor-style = block
cursor-color = #56b6c2
cursor-text = #1e2127
cursor-opacity = 0.8

# Enable cursor blinking
cursor-style-blink = true

# Allow shell integration to change cursor
cursor-invert-fg-bg = false

# Key remappings
macos-option-as-alt = true

# Performance
auto-update = check

# Render settings for sharper text
# If text looks blurry, try uncommenting:
# font-thicken = true
# font-thicken-strength = 0.5
