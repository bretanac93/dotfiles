#!/usr/bin/env bash
#
# Dotfiles health check - verify everything is working
# Usage: dotfiles-doctor

set -e

ERRORS=0
WARNINGS=0

print_header() {
    echo ""
    echo "🔍 Dotfiles Health Check"
    echo "========================"
    echo ""
}

print_ok() {
    echo "  ✅ $1"
}

print_error() {
    echo "  ❌ $1"
    ((ERRORS++))
}

print_warning() {
    echo "  ⚠️  $1"
    ((WARNINGS++))
}

check_symlink() {
    local src="$1"
    local dst="$2"
    local name="$3"
    
    if [[ -L "$dst" ]]; then
        local current_src=$(readlink "$dst")
        if [[ "$current_src" == "$src" ]]; then
            print_ok "$name: correctly linked"
        else
            print_error "$name: links to wrong location ($current_src)"
        fi
    elif [[ -e "$dst" ]]; then
        print_error "$name: exists but is not a symlink"
    else
        print_error "$name: not found"
    fi
}

print_header

echo "Checking symlinks..."
echo ""

# Check core configs
check_symlink "$PWD/zsh/env.zsh" "$HOME/.zshenv" "zshenv"
check_symlink "$PWD/zsh/profile.zsh" "$HOME/.zprofile" "zprofile"
check_symlink "$PWD/zsh/rc.zsh" "$HOME/.zshrc" "zshrc"
check_symlink "$PWD/zsh" "$HOME/.config/zsh" "zsh config"
check_symlink "$PWD/nvim" "$HOME/.config/nvim" "nvim"
check_symlink "$PWD/tmux/tmux.conf" "$HOME/.tmux.conf" "tmux"
check_symlink "$PWD/ghostty" "$HOME/.config/ghostty" "ghostty"
check_symlink "$PWD/git/gitconfig" "$HOME/.gitconfig" "gitconfig"
check_symlink "$PWD/git/gpg.conf" "$HOME/.gnupg/gpg.conf" "gpg"

echo ""
echo "Checking tools..."
echo ""

# Check if tools are in PATH
for tool in wb setup-ssh setup-git-local check-deps; do
    if command -v "$tool" &> /dev/null; then
        print_ok "$tool: available in PATH"
    else
        print_warning "$tool: not in PATH (run init.sh)"
    fi
done

echo ""
echo "Checking 1Password integration..."
echo ""

if command -v op &> /dev/null; then
    if op account list &> /dev/null; then
        print_ok "1Password CLI: authenticated"
        
        # Check SSH key
        if [[ -f "$HOME/.ssh/id_rsa" ]]; then
            print_ok "SSH key: id_rsa exists"
        else
            print_warning "SSH key: run setup-ssh"
        fi
        
        # Check git config
        if [[ -f "$HOME/.config/git/config.local" ]]; then
            print_ok "Git config: local config exists"
        else
            print_warning "Git config: run setup-git-local"
        fi
    else
        print_warning "1Password CLI: installed but not authenticated"
        print "     Run: op signin (requires 1Password app to be unlocked)"
    fi
else
    print_warning "1Password CLI: not installed"
    print "     Run: brew install --cask 1password 1password-cli"
fi

echo ""
echo "Checking SSH..."
echo ""

if [[ -f "$HOME/.ssh/id_rsa" ]]; then
    if ssh-keygen -l -f "$HOME/.ssh/id_rsa" &> /dev/null; then
        print_ok "SSH key: valid format"
    else
        print_error "SSH key: invalid format (run setup-ssh again)"
    fi
    
    # Test GitHub connection (don't fail if it doesn't work, just warn)
    if ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
        print_ok "GitHub SSH: working"
    else
        print_warning "GitHub SSH: not working (may need to add key to GitHub)"
    fi
fi

echo ""
echo "Checking GPG..."
echo ""

if command -v gpg &> /dev/null; then
    print_ok "GPG: installed"
    
    # Check for signing key
    if gpg --list-secret-keys --keyid-format=short 2>/dev/null | grep -q "sec"; then
        print_ok "GPG keys: found"
        
        # Check git signing config
        if git config --get user.signingkey &> /dev/null; then
            print_ok "Git signing: configured"
        else
            print_warning "Git signing: not configured (run setup-git-local)"
        fi
    else
        print_warning "GPG keys: none found (run setup-git-local)"
    fi
else
    print_warning "GPG: not installed (run init.sh to install)"
fi

echo ""
echo "========================"

if [[ $ERRORS -eq 0 && $WARNINGS -eq 0 ]]; then
    echo "✅ All checks passed!"
elif [[ $ERRORS -eq 0 ]]; then
    echo "⚠️  $WARNINGS warning(s) found (non-critical)"
else
    echo "❌ $ERRORS error(s) and $WARNINGS warning(s) found"
    echo ""
    echo "Run ./init.sh to fix most issues"
fi

echo ""

exit $ERRORS
