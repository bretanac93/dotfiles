#!/usr/bin/env zsh
#
# mdf - My Dotfiles Manager
# Usage: mdf <command> [options]

set -e

# Find the actual script location (resolve symlinks)
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"
DOTFILES_DIR="${SCRIPT_DIR:h}"  # Go up one level from bin/

VERSION="1.0.0"

show_help() {
    cat << EOF
mdf - My Dotfiles Manager v${VERSION}

Usage: mdf <command> [options]

Commands:
  install, i       Run init.sh to set up dotfiles
  update, u        Pull latest changes and re-run init
  doctor, d        Check if everything is working
  uninstall       Remove dotfiles (with --dry-run support)
  aliases, a      Show available aliases
  
Setup Commands:
  ssh              Export SSH keys from 1Password
  git              Configure git with GPG signing from 1Password
  
Other:
  version, v       Show version
  help, h          Show this help

Examples:
  mdf install              # First time setup
  mdf update               # Update to latest
  mdf doctor               # Check health
  mdf aliases              # Show all aliases
  mdf uninstall --dry-run  # Preview uninstall

EOF
}

show_aliases() {
    echo "📋 Dotfiles Aliases"
    echo "===================="
    echo ""
    echo "Git Aliases:"
    echo "  g          → git"
    echo "  ga         → git add"
    echo "  gaa        → git add --all"
    echo "  gst        → git status"
    echo "  gd         → git diff"
    echo "  gds        → git diff --staged"
    echo "  gco        → git checkout"
    echo "  gcb        → git checkout -b"
    echo "  gcm        → git commit -m"
    echo "  gcam       → git commit -a -m"
    echo "  gp         → git push"
    echo "  gpf        → git push --force-with-lease"
    echo "  gl         → git pull"
    echo "  gupa       → git pull --rebase --autostash"
    echo "  glo        → git log --oneline --decorate"
    echo "  glog       → git log --oneline --decorate --graph"
    echo "  gsw        → git switch"
    echo "  gstp       → git stash pop"
    echo ""
    echo "Navigation Aliases:"
    echo "  ..         → cd .."
    echo "  ...        → cd ../.."
    echo "  ....       → cd ../../.."
    echo "  .....      → cd ../../../.."
    echo "  -          → cd -"
    echo ""
    echo "File Listing Aliases:"
    echo "  l          → ls -l"
    echo "  la         → ls -a"
    echo "  ll         → ls -la"
    echo "  lt         → ls --tree"
    echo "  l.         → ls -d .*"
    echo ""
    echo "Editor Aliases:"
    echo "  vim        → nvim"
    echo "  v          → nvim"
    echo ""
    echo "Run 'alias | grep YOUR_TERM' to find specific aliases"
}

run_script() {
    local script="$1"
    shift
    
    if [[ -x "$DOTFILES_DIR/bin/$script" ]]; then
        exec "$DOTFILES_DIR/bin/$script" "$@"
    elif [[ -x "$DOTFILES_DIR/scripts/$script" ]]; then
        exec "$DOTFILES_DIR/scripts/$script" "$@"
    else
        echo "❌ Command not found: $script"
        exit 1
    fi
}

# Parse command
case "${1:-}" in
    install|i)
        shift
        cd "$DOTFILES_DIR"
        exec ./init.sh "$@"
        ;;
        
    update|u)
        shift
        run_script "dotfiles-update" "$@"
        ;;
        
    doctor|d)
        shift
        run_script "dotfiles-doctor" "$@"
        ;;
        
    cleanup|c)
        shift
        run_script "dotfiles-cleanup-backups" "$@"
        ;;
        
    uninstall|remove|rm)
        shift
        run_script "dotfiles-uninstall" "$@"
        ;;
        
    ssh)
        shift
        run_script "setup-ssh" "$@"
        ;;
        
    git)
        shift
        run_script "setup-git-local" "$@"
        ;;
        
    aliases|a)
        show_aliases
        exit 0
        ;;
        
    version|v|--version|-v)
        echo "mdf version ${VERSION}"
        exit 0
        ;;
        
    help|h|--help|-h|"")
        show_help
        exit 0
        ;;
        
    *)
        echo "❌ Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
