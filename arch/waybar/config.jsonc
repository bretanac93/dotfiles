{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 8,
  "modules-left": [
    "hyprland/workspaces",
    "custom/claude-usage",
    "custom/codex-usage"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "network",
    "custom/cpu-status",
    "custom/gpu-status",
    "memory",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": false,
    "disable-scroll": true,
    "format": "{name}",
    "persistent-workspaces": {
      "*": 10
    }
  },
  "hyprland/window": {
    "format": "{class}",
    "max-length": 48,
    "separate-outputs": true,
    "rewrite": {
      "": "Desktop",
      "com.mitchellh.ghostty": "Ghostty",
      "firefox": "Firefox"
    }
  },
  "custom/media": {
    "exec": "waybar-media",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "max-length": 48,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl stop",
    "on-click-middle": "hypr-launcher",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "mute",
    "format-icons": {
      "default": [
        "vol",
        "vol",
        "vol"
      ]
    },
    "scroll-step": 5,
    "on-click": "hypr-audio-menu",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "network": {
    "format-wifi": "wifi",
    "format-ethernet": "eth",
    "format-disconnected": "offline",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "hypr-wifi-menu",
    "on-click-right": "hypr-bluetooth-menu"
  },
  "custom/cpu-status": {
    "exec": "waybar-cpu-temp",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "on-click": "waybar-toggle-mode cpu"
  },
  "custom/gpu-status": {
    "exec": "waybar-gpu-temp",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "on-click": "waybar-toggle-mode gpu"
  },
  "memory": {
    "format": "mem {}%",
    "tooltip": false
  },
  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#81a1c1'><b>{}</b></span>",
        "days": "<span color='#d8dee9'><b>{}</b></span>",
        "weeks": "<span color='#4c566a'><b>W{}</b></span>",
        "weekdays": "<span color='#88c0d0'><b>{}</b></span>",
        "today": "<span color='#2e3440' background='#88c0d0'><b>{}</b></span>"
      }
    }
  },
  "custom/power": {
    "format": "\u23fb",
    "tooltip": false,
    "on-click": "hypr-power-menu"
  },
  "tray": {
    "spacing": 10
  },
  "custom/claude-usage": {
    "exec": "/usr/bin/claude-usage --waybar --browser vivaldi",
    "return-type": "json",
    "interval": 120,
    "format": "{}",
    "tooltip": true,
    "on-click": "pkill -RTMIN+8 waybar",
    "signal": 8
  },
  "custom/codex-usage": {
    "exec": "/usr/bin/codex-usage --waybar --browser vivaldi",
    "return-type": "json",
    "interval": 120,
    "format": "{}",
    "tooltip": true,
    "on-click": "pkill -RTMIN+9 waybar",
    "signal": 9
  }
}
