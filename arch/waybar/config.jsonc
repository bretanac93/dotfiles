{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 8,
  "modules-left": [
    "hyprland/workspaces",
    "custom/claude-usage",
    "custom/codex-usage"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "group/tray-drawer",
    "pulseaudio",
    "bluetooth",
    "network",
    "custom/system-stats",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": false,
    "disable-scroll": true,
    "format": "{name}",
    "persistent-workspaces": {
      "*": 10
    }
  },
  "hyprland/window": {
    "format": "{class}",
    "max-length": 48,
    "separate-outputs": true,
    "rewrite": {
      "": "Desktop",
      "com.mitchellh.ghostty": "Ghostty",
      "firefox": "Firefox"
    }
  },
  "custom/media": {
    "exec": "waybar-media",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "max-length": 48,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl stop",
    "on-click-middle": "hypr-launcher",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "󰖁",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "tooltip-format": "{volume}%  {desc}",
    "scroll-step": 5,
    "on-click": "hypr-audio-menu",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "bluetooth": {
    "format": "󰂯",
    "format-off": "󰂲",
    "format-disabled": "󰂲",
    "format-connected": "󰂱",
    "format-no-controller": "",
    "tooltip-format": "󰂯 {status}",
    "tooltip-format-connected": "{device_alias}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "ghostty -e bluetui",
    "on-click-right": "hypr-bluetooth-menu"
  },
  "network": {
    "format-wifi": "󰖩",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰖪",
    "tooltip-format-wifi": "{essid}  {signalStrength}%",
    "tooltip-format-ethernet": "{ifname}  {ipaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "hypr-wifi-menu"
  },
  "custom/system-stats": {
    "exec": "waybar-system-stats",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "on-click": "ghostty -e btop",
    "tooltip": true
  },
  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#81a1c1'><b>{}</b></span>",
        "days": "<span color='#d8dee9'><b>{}</b></span>",
        "weeks": "<span color='#4c566a'><b>W{}</b></span>",
        "weekdays": "<span color='#88c0d0'><b>{}</b></span>",
        "today": "<span color='#2e3440' background='#88c0d0'><b>{}</b></span>"
      }
    }
  },
  "group/tray-drawer": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "tray-item",
      "transition-left-to-right": false
    },
    "modules": ["custom/tray-toggle", "tray"]
  },
  "custom/tray-toggle": {
    "format": "‹",
    "tooltip": false
  },
  "tray": {
    "icon-size": 16,
    "spacing": 12
  },
  "custom/power": {
    "format": "\u23fb",
    "tooltip": false,
    "on-click": "hypr-power-menu"
  },
  "custom/1password": {
    "exec": "waybar-app-indicator 1password  1Password",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "1password",
    "tooltip": true
  },
  "custom/cider": {
    "exec": "waybar-app-indicator cider  Cider",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "cider",
    "tooltip": true
  },
  "custom/signal": {
    "exec": "waybar-app-indicator signal-desktop  Signal",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "signal-desktop",
    "tooltip": true
  },
  "custom/telegram": {
    "exec": "waybar-app-indicator telegram-desktop  Telegram",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "telegram-desktop",
    "tooltip": true
  },
  "custom/slack": {
    "exec": "waybar-app-indicator slack  Slack",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "slack",
    "tooltip": true
  },
  "custom/steam": {
    "exec": "waybar-app-indicator steam  Steam",
    "return-type": "json",
    "interval": 3,
    "format": "{}",
    "on-click": "steam",
    "tooltip": true
  },
  "custom/dnd": {
    "exec": "swaync-client --subscribe-waybar",
    "return-type": "json",
    "format": "{icon}{} ",
    "format-icons": {
      "none": "",
      "notification": "  ",
      "dnd-none": "dnd",
      "dnd-notification": "dnd  ",
      "inhibited-none": "",
      "inhibited-notification": "  ",
      "dnd-inhibited-none": "dnd",
      "dnd-inhibited-notification": "dnd  "
    },
    "on-click": "swaync-client -d -sw",
    "on-click-right": "swaync-client -t -sw",
    "tooltip": false,
    "escape": true
  },
  "custom/claude-usage": {
    "exec": "/usr/bin/claude-usage --waybar --browser vivaldi",
    "return-type": "json",
    "interval": 120,
    "format": "{}",
    "tooltip": true,
    "on-click": "pkill -RTMIN+8 waybar",
    "signal": 8
  },
  "custom/codex-usage": {
    "exec": "/usr/bin/codex-usage --waybar --browser vivaldi",
    "return-type": "json",
    "interval": 120,
    "format": "{}",
    "tooltip": true,
    "on-click": "pkill -RTMIN+9 waybar",
    "signal": 9
  }
}
